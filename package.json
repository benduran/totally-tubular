{
  "license": "MIT",
  "description": "A completely framework-agnostic, JavaScript / TypeScript state management and update broadcasting library wit zero dependencies, solid performance and a micro file size.",
  "name": "totally-tubular",
  "type": "module",
  "main": "./dist/totally-tubular.js",
  "types": "./dist/totally-tubular.d.ts",
  "typings": "./dist/totally-tubular.d.ts",
  "version": "0.3.2",
  "keywords": [
    "state",
    "management",
    "state management",
    "zero-dependencies",
    "zero dependencies",
    "fast",
    "simple",
    "agnostic",
    "framework agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benduran/totally-tubular.git"
  },
  "bugs": {
    "url": "https://github.com/benduran/totally-tubular/issues"
  },
  "homepage": "https://github.com/benduran/totally-tubular#readme",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "ts-duality --clean",
    "clean": "rm -rf dist/",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@better-builds/lets-version": "^1.6.0",
    "@better-builds/ts-duality": "^1.3.2",
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@happy-dom/global-registrator": "^20.8.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": ">=18",
    "happy-dom": "^20.8.3",
    "react": ">=18",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "react": ">=18"
  },
  "exports": {
    "./react": {
      "require": {
        "types": "./dist/cjs/react.d.ts",
        "default": "./dist/cjs/react.cjs"
      },
      "import": {
        "types": "./dist/esm/react.d.ts",
        "default": "./dist/esm/react.mjs"
      }
    },
    "./totally-tubular": {
      "require": {
        "types": "./dist/cjs/totally-tubular.d.ts",
        "default": "./dist/cjs/totally-tubular.cjs"
      },
      "import": {
        "types": "./dist/esm/totally-tubular.d.ts",
        "default": "./dist/esm/totally-tubular.mjs"
      }
    },
    "./types": {
      "require": {
        "types": "./dist/cjs/types.d.ts",
        "default": "./dist/cjs/types.cjs"
      },
      "import": {
        "types": "./dist/esm/types.d.ts",
        "default": "./dist/esm/types.mjs"
      }
    },
    "./package.json": "./package.json"
  }
}
