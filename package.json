{
  "license": "MIT",
  "description": "A completely framework-agnostic, JavaScript / TypeScript state management and update broadcasting library wit zero dependencies, solid performance and a micro file size.",
  "name": "totally-tubular",
  "type": "module",
  "version": "0.3.3",
  "keywords": [
    "state",
    "management",
    "state management",
    "zero-dependencies",
    "zero dependencies",
    "fast",
    "simple",
    "agnostic",
    "framework agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benduran/totally-tubular.git"
  },
  "bugs": {
    "url": "https://github.com/benduran/totally-tubular/issues"
  },
  "homepage": "https://github.com/benduran/totally-tubular#readme",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rm -rf dist/ && tsc --project ./tsconfig.build.json",
    "clean": "rm -rf dist/",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@better-builds/lets-version": "^1.6.0",
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "happy-dom": "^20.9.0",
    "react": ">=18",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./totally-tubular": {
      "types": "./dist/totally-tubular.d.ts",
      "default": "./dist/totally-tubular.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  }
}
